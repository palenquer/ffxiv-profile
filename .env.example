# ─── FFXIV Profile Configuration ───────────────────────────────────────────
#
# 1. Copy this file to .env.local
# 2. Set the Lodestone ID of the character
# 3. Run: npm run setup
#
# The Lodestone ID is the number in the character's Lodestone URL:
#   https://na.finalfantasyxiv.com/lodestone/character/48463380/
#                                                        ^^^^^^^^
#                                                     This is the ID
#
# ────────────────────────────────────────────────────────────────────────────

LODESTONE_ID=48463380

# ─── Vercel Build ────────────────────────────────────────────────────────────
#
# To auto-refresh character data on every Vercel deploy:
#   1. Set LODESTONE_ID in your Vercel project's Environment Variables
#   2. Change the Build Command in Vercel to:
#        npm run build:fresh
#
# This will fetch fresh data (name, jobs, portrait) on every deploy.
#
# ─────────────────────────────────────────────────────────────────────────────
